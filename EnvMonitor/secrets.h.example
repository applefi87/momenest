// ==========================================================
// 機密設定範本
// 使用方式：複製本檔為 secrets.h 並填入實際值。
// secrets.h 已被 .gitignore 排除，不會被 commit。
// ==========================================================
#pragma once

#define WIFI_SSID   "你的WiFi名稱"
#define WIFI_PASS   "你的WiFi密碼"

// Cloudflare Worker 部署後的網址 (見 cloud/README.md)
#define API_URL     "https://env-monitor.你的帳號.workers.dev/api/ingest"

// 上傳密鑰：需與 `wrangler secret put API_KEY` 設定的值一致
// 建議用長隨機字串，例如: openssl rand -hex 24
#define API_KEY     "換成你的隨機密鑰"

// OTA 無線更新密碼 (Arduino IDE 網路埠上傳時輸入)
#define OTA_PASS    "換成你的OTA密碼"
